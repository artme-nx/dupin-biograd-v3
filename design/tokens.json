{
  "$schema": "https://design-tokens.org/schema.json",
  "primitive": {
    "color": {
      "paper": {
        "50": { "$value": "#FBF4E1", "$type": "color" },
        "100": { "$value": "#F3E6C4", "$type": "color" },
        "200": { "$value": "#E8D6A6", "$type": "color" },
        "300": { "$value": "#D8C08A", "$type": "color" },
        "400": { "$value": "#C4A76E", "$type": "color" }
      },
      "ink": {
        "900": { "$value": "#241A10", "$type": "color" },
        "700": { "$value": "#3E2D1B", "$type": "color" },
        "500": { "$value": "#5E4A31", "$type": "color" },
        "300": { "$value": "#8A7455", "$type": "color" }
      },
      "sea": {
        "900": { "$value": "#0C3638", "$type": "color" },
        "700": { "$value": "#154D4E", "$type": "color" },
        "500": { "$value": "#1F6668", "$type": "color" },
        "300": { "$value": "#4C8C8A", "$type": "color" }
      },
      "rust": {
        "700": { "$value": "#7A2D1F", "$type": "color" },
        "600": { "$value": "#9C3A26", "$type": "color" },
        "500": { "$value": "#B8492F", "$type": "color" },
        "300": { "$value": "#D28362", "$type": "color" }
      },
      "brass": {
        "600": { "$value": "#8B6B2A", "$type": "color" },
        "500": { "$value": "#A9812E", "$type": "color" },
        "300": { "$value": "#C9A85C", "$type": "color" }
      }
    },
    "font": {
      "display": { "$value": "var(--font-chart-hand), 'IM Fell English', Georgia, serif", "$type": "fontFamily" },
      "serif": { "$value": "var(--font-chart-body), 'Spectral', Georgia, serif", "$type": "fontFamily" },
      "mono": { "$value": "var(--font-chart-mono), 'Special Elite', 'Courier New', monospace", "$type": "fontFamily" }
    },
    "motion": {
      "duration": {
        "micro": { "$value": "180ms", "$type": "duration" },
        "base": { "$value": "420ms", "$type": "duration" },
        "reveal": { "$value": "900ms", "$type": "duration" },
        "drift": { "$value": "6000ms", "$type": "duration" }
      },
      "ease": {
        "out-expo": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" },
        "chart": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier" }
      }
    },
    "tracking": {
      "display": { "$value": "0.01em", "$type": "dimension" },
      "label": { "$value": "0.22em", "$type": "dimension" }
    }
  },
  "semantic": {
    "background": { "$value": "{primitive.color.paper.100}", "$type": "color" },
    "foreground": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "card": { "$value": "{primitive.color.paper.50}", "$type": "color" },
    "card-foreground": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "popover": { "$value": "{primitive.color.paper.50}", "$type": "color" },
    "popover-foreground": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "primary": { "$value": "{primitive.color.sea.900}", "$type": "color" },
    "primary-foreground": { "$value": "{primitive.color.paper.50}", "$type": "color" },
    "secondary": { "$value": "{primitive.color.paper.200}", "$type": "color" },
    "secondary-foreground": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "muted": { "$value": "{primitive.color.paper.200}", "$type": "color" },
    "muted-foreground": { "$value": "{primitive.color.ink.500}", "$type": "color" },
    "accent": { "$value": "{primitive.color.paper.300}", "$type": "color" },
    "accent-foreground": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "destructive": { "$value": "{primitive.color.rust.700}", "$type": "color" },
    "border": { "$value": "{primitive.color.ink.300}", "$type": "color" },
    "input": { "$value": "{primitive.color.paper.300}", "$type": "color" },
    "ring": { "$value": "{primitive.color.sea.500}", "$type": "color" },
    "radius": { "$value": "0.125rem", "$type": "dimension" },
    "route": { "$value": "{primitive.color.rust.600}", "$type": "color" },
    "route-dim": { "$value": "{primitive.color.rust.300}", "$type": "color" },
    "compass": { "$value": "{primitive.color.sea.900}", "$type": "color" },
    "compass-accent": { "$value": "{primitive.color.brass.500}", "$type": "color" },
    "sounding": { "$value": "{primitive.color.ink.300}", "$type": "color" },
    "surface-line": { "$value": "{primitive.color.ink.300}", "$type": "color" },
    "type-display": { "$value": "{primitive.font.display}", "$type": "fontFamily" },
    "type-body": { "$value": "{primitive.font.serif}", "$type": "fontFamily" },
    "type-label": { "$value": "{primitive.font.mono}", "$type": "fontFamily" },
    "ease-reveal": { "$value": "{primitive.motion.ease.out-expo}", "$type": "cubicBezier" },
    "ease-chart": { "$value": "{primitive.motion.ease.chart}", "$type": "cubicBezier" },
    "duration-micro": { "$value": "{primitive.motion.duration.micro}", "$type": "duration" },
    "duration-base": { "$value": "{primitive.motion.duration.base}", "$type": "duration" },
    "duration-reveal": { "$value": "{primitive.motion.duration.reveal}", "$type": "duration" },
    "tracking-display": { "$value": "{primitive.tracking.display}", "$type": "dimension" },
    "tracking-label": { "$value": "{primitive.tracking.label}", "$type": "dimension" }
  },
  "component": {
    "hero": {
      "title-size": { "$value": "clamp(3rem, 9vw, 7.5rem)", "$type": "dimension" },
      "title-leading": { "$value": "0.98", "$type": "number" },
      "kicker-size": { "$value": "0.72rem", "$type": "dimension" },
      "vignette": {
        "$value": "radial-gradient(ellipse 120% 80% at 50% 0%, rgba(36,26,16,0.0), rgba(36,26,16,0.14) 100%)",
        "$type": "gradient"
      }
    },
    "pin": {
      "size": { "$value": "2.75rem", "$type": "dimension" },
      "ring": { "$value": "{primitive.color.rust.600}", "$type": "color" }
    },
    "button": {
      "primary-bg": { "$value": "{primitive.color.sea.900}", "$type": "color" },
      "primary-fg": { "$value": "{primitive.color.paper.50}", "$type": "color" },
      "primary-hover-bg": { "$value": "{primitive.color.rust.600}", "$type": "color" },
      "primary-hover-fg": { "$value": "{primitive.color.paper.50}", "$type": "color" },
      "ghost-border": { "$value": "{primitive.color.ink.500}", "$type": "color" },
      "ghost-hover-border": { "$value": "{primitive.color.rust.600}", "$type": "color" }
    }
  }
}
